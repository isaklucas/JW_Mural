# Copie este arquivo para `.env` e ajuste os valores.
# O `.env` NÃO é versionado (contém a URI do banco; em produção pode ter usuário/senha).

# Tipo de banco de dados: mongodb (padrão) ou dynamodb
DB_TYPE=mongodb

# --- MongoDB ---
# Local: mongodb://localhost:27017/
# Atlas: mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/  (mantenha em segredo)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=jw_mural
MONGODB_COLLECTION=publicadores

# --- DynamoDB (alternativa) ---
# AWS_REGION=us-east-1
# DYNAMODB_TABLE=publicadores
# Credenciais AWS via variáveis de ambiente / perfil (NÃO coloque chaves aqui)
